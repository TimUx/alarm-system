# =============================================================================
# Alarm System - Central Configuration
# =============================================================================
# This file contains all configuration for the integrated alarm system:
# - alarm-mail: IMAP email parser
# - alarm-monitor: Dashboard for displaying alarms
# - alarm-messenger: Mobile push notification system
#
# Copy this file to .env and customize the values for your installation.
# =============================================================================

# =============================================================================
# GENERAL CONFIGURATION
# =============================================================================

# Timezone for all services
TZ=Europe/Berlin

# =============================================================================
# ALARM MAIL SERVICE CONFIGURATION
# =============================================================================
# The alarm-mail service polls an IMAP mailbox for alarm emails and forwards
# them to alarm-monitor and alarm-messenger.

# IMAP Configuration (Required)
ALARM_MAIL_IMAP_HOST=imap.example.com
ALARM_MAIL_IMAP_PORT=993
ALARM_MAIL_IMAP_USE_SSL=true
ALARM_MAIL_IMAP_USERNAME=alarm@example.com
ALARM_MAIL_IMAP_PASSWORD=change-me
ALARM_MAIL_IMAP_MAILBOX=INBOX
ALARM_MAIL_IMAP_SEARCH=UNSEEN
ALARM_MAIL_POLL_INTERVAL=60

# Optional: HTTP request timeout in seconds (default: 10)
# ALARM_MAIL_HTTP_TIMEOUT=10

# Optional: Log level (DEBUG, INFO, WARNING, ERROR; default: INFO)
# ALARM_MAIL_LOG_LEVEL=INFO

# Optional: Deduplication TTL in seconds - alarms seen within this window are suppressed (default: 300)
# ALARM_MAIL_DEDUP_TTL=300

# Optional: Path to a SQLite file for persistent deduplication (survives service restarts)
# ALARM_MAIL_DEDUP_DB=/path/to/dedup.db

# =============================================================================
# ALARM MONITOR CONFIGURATION
# =============================================================================
# The alarm-monitor displays alarms on a dashboard.

# Port for accessing the dashboard (external)
ALARM_MONITOR_PORT=8000

# API Key for receiving alarms from alarm-mail service
# Generate with: openssl rand -hex 32
ALARM_MONITOR_API_KEY=change-me-to-random-api-key-for-monitor

# Password for the settings page (required to save settings via web UI)
# Generate with: openssl rand -hex 16
ALARM_MONITOR_SETTINGS_PASSWORD=change-me-to-random-settings-password

# How long to display an alarm before returning to idle view (in minutes)
ALARM_MONITOR_DISPLAY_DURATION=30

# Optional: OpenRouteService API key for navigation/routing
# ALARM_MONITOR_ORS_API_KEY=

# Optional: Prometheus metrics endpoint token (required to enable /api/metrics)
# Generate with: openssl rand -hex 32
# ALARM_MONITOR_METRICS_TOKEN=

# Optional: Custom paths for persistent data files
# ALARM_MONITOR_HISTORY_FILE=/custom/path/to/alarm_history.json
# ALARM_MONITOR_SETTINGS_FILE=/custom/path/to/settings.json

# =============================================================================
# ALARM MESSENGER CONFIGURATION
# =============================================================================
# The alarm-messenger sends push notifications to mobile devices via WebSocket.

# Port for accessing the admin interface and WebSocket (external)
ALARM_MESSENGER_PORT=3000

# Server URL for QR code generation (must be externally accessible)
# Examples:
#   Development: http://localhost:3000
#   Production:  https://messenger.your-domain.com
ALARM_MESSENGER_SERVER_URL=http://localhost:3000

# API Secret Key for receiving alarms from alarm-mail service
# Generate with: openssl rand -hex 32
# Can be Base64 encoded for additional obfuscation (optional)
ALARM_MESSENGER_API_SECRET_KEY=change-me-to-random-api-key-for-messenger

# JWT Secret for admin interface authentication
# Generate with: openssl rand -hex 32
# Can be Base64 encoded for additional obfuscation (optional)
ALARM_MESSENGER_JWT_SECRET=change-me-to-random-jwt-secret

# Session Secret for admin session management
# Generate with: openssl rand -hex 32
ALARM_MESSENGER_SESSION_SECRET=change-me-to-random-session-secret

# Organization/Fire Department Name
# This name is displayed in the mobile app and admin interface
ALARM_MESSENGER_ORGANIZATION_NAME=Feuerwehr Musterstadt

# CORS Origins (comma-separated allowed origins, or * for all)
# For production, specify your mobile app domain
ALARM_MESSENGER_CORS_ORIGINS=*

# Push Notifications (Optional - for better background delivery)
# Firebase Cloud Messaging (FCM) - for Android
# Set to 'true' to enable FCM push notifications
ALARM_MESSENGER_ENABLE_FCM=false
# Path to your Firebase service account JSON file
# Download from Firebase Console > Project Settings > Service Accounts
# ALARM_MESSENGER_FCM_SERVICE_ACCOUNT_PATH=/path/to/firebase-service-account.json

# Apple Push Notification service (APNs) - for iOS
# Set to 'true' to enable APNs push notifications
ALARM_MESSENGER_ENABLE_APNS=false
# Path to your APNs .p8 key file
# ALARM_MESSENGER_APNS_KEY_PATH=/path/to/AuthKey_XXXXXXXXXX.p8
# APNs Key ID (10-character string from Apple Developer Portal)
# ALARM_MESSENGER_APNS_KEY_ID=XXXXXXXXXX
# Apple Team ID (10-character string from Apple Developer Portal)
# ALARM_MESSENGER_APNS_TEAM_ID=XXXXXXXXXX
# APNs topic (your app's bundle identifier)
# ALARM_MESSENGER_APNS_TOPIC=com.alarmmessenger
# APNs environment (true for production, false for development/sandbox)
# ALARM_MESSENGER_APNS_PRODUCTION=false

# =============================================================================
# OPTIONAL: REVERSE PROXY CONFIGURATION (CADDY)
# =============================================================================
# If using the optional Caddy reverse proxy for SSL/TLS termination,
# configure the domain names here.
# Enable Caddy with: docker-compose --profile with-caddy up

# Domain for alarm-monitor dashboard
ALARM_MONITOR_DOMAIN=monitor.example.com

# Domain for alarm-messenger (admin interface and WebSocket)
ALARM_MESSENGER_DOMAIN=messenger.example.com

# =============================================================================
# NOTES
# =============================================================================
# 1. All services communicate internally via the 'alarm-network' Docker network
# 2. Only alarm-monitor and alarm-messenger need external port access
# 3. alarm-mail has no external ports - it only needs outgoing IMAP access
# 4. API keys must match between services:
#    - ALARM_MONITOR_API_KEY must be the same for alarm-mail and alarm-monitor
#    - ALARM_MESSENGER_API_SECRET_KEY must be the same for alarm-mail and alarm-messenger
# 5. Generate strong random API keys before deployment!
# 6. For production use, enable Caddy for automatic HTTPS

# =============================================================================
# PRODUCTION HARDENING: Docker Secrets (optional)
# =============================================================================
# Plain environment variables are visible to any user with Docker socket access
# via "docker inspect". For production deployments, consider using Docker Secrets
# to pass sensitive values out-of-band.
#
# Option A — File-based secrets (*_FILE convention, if supported by the service):
#   Some images read <VAR>_FILE and load the value from a mounted file, e.g.:
#   ALARM_MAIL_IMAP_PASSWORD_FILE=/run/secrets/imap_password
#   Mount the secret into the container and reference it in docker-compose.yml:
#     secrets:
#       - imap_password
#     environment:
#       - ALARM_MAIL_IMAP_PASSWORD_FILE=/run/secrets/imap_password
#
# Option B — Docker Swarm secrets (docker secret create):
#   echo "mysecretvalue" | docker secret create imap_password -
#   Then reference it in your stack's compose file:
#     secrets:
#       imap_password:
#         external: true
#
# Sensitive values to protect:
#   ALARM_MAIL_IMAP_PASSWORD
#   ALARM_MONITOR_API_KEY
#   ALARM_MONITOR_SETTINGS_PASSWORD
#   ALARM_MESSENGER_API_SECRET_KEY
#   ALARM_MESSENGER_JWT_SECRET
#   ALARM_MESSENGER_SESSION_SECRET
#   ALARM_MESSENGER_FCM_SERVICE_ACCOUNT_PATH (file path to credentials)
#   ALARM_MESSENGER_APNS_KEY_PATH            (file path to credentials)
